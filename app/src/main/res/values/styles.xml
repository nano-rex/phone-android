<resources>
    <style name="Theme.ConvoyPhone.Light" parent="@android:style/Theme.DeviceDefault.Light.NoActionBar">
        <item name="android:buttonStyle">@style/Widget.ConvoyPhone.Button</item>
    </style>

    <style name="Theme.ConvoyPhone.Dark" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <item name="android:buttonStyle">@style/Widget.ConvoyPhone.Button</item>
    </style>

    <style name="Widget.ConvoyPhone.Button" parent="@android:style/Widget.DeviceDefault.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center</item>
        <item name="android:singleLine">false</item>
        <item name="android:maxLines">2</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:paddingLeft">12dp</item>
        <item name="android:paddingRight">12dp</item>
    </style>
</resources>
