<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/settings" android:textSize="24sp" android:textStyle="bold" />

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/default_dialer" android:layout_marginTop="12dp" />
        <TextView android:id="@+id/default_dialer_status" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" />
        <Button android:id="@+id/request_default_dialer_button" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/request_default_dialer" android:layout_marginTop="8dp" />

        <Switch android:id="@+id/dark_mode_switch" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/dark_mode" android:layout_marginTop="12dp" />
        <Switch android:id="@+id/record_calls_switch" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/record_calls" android:layout_marginTop="12dp" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/recording_source" android:layout_marginTop="12dp" />
        <RadioGroup android:id="@+id/recording_source_group" android:layout_width="match_parent" android:layout_height="wrap_content">
            <RadioButton android:id="@+id/source_environment" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/source_environment" />
            <RadioButton android:id="@+id/source_device" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/source_device" />
        </RadioGroup>
        <Button android:id="@+id/choose_folder_button" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/open_folder_picker" android:layout_marginTop="12dp" />
        <TextView android:id="@+id/folder_status" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/recording_note" android:layout_marginTop="8dp" />
        <include layout="@layout/bottom_nav" />
    </LinearLayout>
</ScrollView>
